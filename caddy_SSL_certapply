    echo -e "${YELLOW}2. 配置后端服务${NC}"
    read -p "请输入后端端口 (如 8080): " backend_port
    if [ -z "$backend_port" ]; then
        error_exit "后端端口不能为空"
    fi
    
    read -p "后端地址 [默认: localhost]: " backend_host
    backend_host=${backend_host:-localhost}
    
    # 高级选项
    echo ""
    echo -e "${YELLOW}3. 高级选项${NC}"
    read -p "是否需要 WebSocket 支持? (y/n) [默认: n]: " ws_support
    read -p "是否启用访问日志? (y/n) [默认: n]: " enable_log
    
    # 生成配置
    echo "" >> "$CADDYFILE"
    echo "# 服务: $address" >> "$CADDYFILE"
    echo "$address {" >> "$CADDYFILE"
    
    if [[ $enable_log =~ ^[Yy]$ ]]; then
        echo "    log {" >> "$CADDYFILE"
        echo "        output file /var/log/caddy/${address//[:\/.]/}_access.log" >> "$CADDYFILE"
        echo "    }" >> "$CADDYFILE"
        mkdir -p /var/log/caddy
    fi
    
    echo "    reverse_proxy $backend_host:$backend_port {" >> "$CADDYFILE"
    echo "        header_up X-Real-IP {remote_host}" >> "$CADDYFILE"
    echo "        header_up X-Forwarded-For {remote_host}" >> "$CADDYFILE"
    echo "        header_up X-Forwarded-Proto {scheme}" >> "$CADDYFILE"
    echo "    }" >> "$CADDYFILE"
    echo "}" >> "$CADDYFILE"
    
    # 验证配置
    echo ""
    info_msg "验证配置..."
    if caddy validate --config "$CADDYFILE" 2>&1 | tee -a "$LOG_FILE"; then
        success_msg "配置验证成功"
        
        # 重载配置
        info_msg "重载 Caddy..."
        if systemctl reload caddy 2>&1 | tee -a "$LOG_FILE"; then
            success_msg "服务配置成功!"
            echo ""
            echo -e "${GREEN}配置信息:${NC}"
            echo -e "  访问地址: ${CYAN}$address${NC}"
            echo -e "  后端地址: $backend_host:$backend_port"
            echo -e "  HTTPS: $([ "$use_ssl" = true ] && echo '启用' || echo '禁用')"
            
            if [ -n "$custom_port" ]; then
                echo -e "  自定义端口: $custom_port"
                echo ""
                echo -e "${YELLOW}防火墙提示:${NC}"
                echo "  需要开放端口 $custom_port"
                echo ""
                read -p "是否自动添加防火墙规则? (y/n): " fw_choice
                if [[ $fw_choice =~ ^[Yy]$ ]]; then
                    case $FIREWALL_TYPE in
                        ufw)
                            ufw allow $custom_port/tcp comment "Caddy custom port"
                            success_msg "UFW 规则已添加"
                            ;;
                        firewalld)
                            firewall-cmd --permanent --add-port=$custom_port/tcp
                            firewall-cmd --reload
                            success_msg "firewalld 规则已添加"
                            ;;
                        iptables)
                            iptables -A INPUT -p tcp --dport $custom_port -j ACCEPT
                            success_msg "iptables 规则已添加"
                            ;;
                    esac
                fi
            fi
            
            if [ "$use_ssl" = true ]; then
                echo ""
                echo -e "${YELLOW}HTTPS 注意事项:${NC}"
                echo "  1. 确保域名已解析到本机 IP"
                echo "  2. Caddy 将自动申请 SSL 证书 (Let's Encrypt)"
                echo "  3. 首次申请可能需要 1-2 分钟"
                if [ -n "$custom_port" ]; then
                    echo "  4. HTTPS 自定义端口访问: https://$domain:$custom_port"
                fi
            fi
        else
            error_exit "重载 Caddy 失败，已恢复备份"
            cp "$CONFIG_BACKUP" "$CADDYFILE"
        fi
    else
        error_exit "配置验证失败，已恢复备份"
        cp "$CONFIG_BACKUP" "$CADDYFILE"
    fi
    
    echo ""
    read -p "按 Enter 继续..."
}

# ============================================
# 查看所有服务
# ============================================
view_services() {
    show_logo
    echo -e "${CYAN}==================== 当前服务 ====================${NC}\n"
    
    if [ ! -f "$CADDYFILE" ]; then
        warning_msg "配置文件不存在"
        read -p "按 Enter 继续..."
        return
    fi
    
    echo -e "${GREEN}Caddyfile 配置:${NC}"
    echo "─────────────────────────────────────────────"
    cat "$CADDYFILE"
    echo "─────────────────────────────────────────────"
    
    echo ""
    echo -e "${GREEN}Caddy 运行状态:${NC}"
    if $HAS_SYSTEMD; then
        systemctl status caddy --no-pager || true
    else
        echo "  无法查看状态 (非 systemd 系统)"
    fi
    
    echo ""
    read -p "按 Enter 继续..."
}

# ============================================
# 删除服务
# ============================================
remove_service() {
    show_logo
    echo -e "${CYAN}==================== 删除服务 ====================${NC}\n"
    
    if [ ! -f "$CADDYFILE" ]; then
        warning_msg "配置文件不存在"
        read -p "按 Enter 继续..."
        return
    fi
    
    echo -e "${YELLOW}当前配置的服务:${NC}\n"
    grep -E "^[^#]*\{" "$CADDYFILE" | sed 's/ {//' | nl -w2 -s'. '
    
    echo ""
    read -p "请输入要删除的服务域名/地址: " target
    
    if [ -z "$target" ]; then
        warning_msg "已取消"
        read -p "按 Enter 继续..."
        return
    fi
    
    # 备份
    cp "$CADDYFILE" "$CONFIG_BACKUP"
    
    # 删除配置块
    sed -i "/^# 服务: $target/,/^}/d" "$CADDYFILE"
    sed -i "/^$target {/,/^}/d" "$CADDYFILE"
    
    # 重载
    if caddy validate --config "$CADDYFILE" && systemctl reload caddy; then
        success_msg "服务已删除"
    else
        error_exit "删除失败，已恢复配置"
        cp "$CONFIG_BACKUP" "$CADDYFILE"
    fi
    
    echo ""
    read -p "按 Enter 继续..."
}

# ============================================
# 管理 Caddy 服务
# ============================================
manage_caddy_service() {
    show_logo
    echo -e "${CYAN}==================== 服务管理 ====================${NC}\n"
    
    if ! $HAS_SYSTEMD; then
        warning_msg "系统不支持 systemctl"
        read -p "按 Enter 继续..."
        return
    fi
    
    echo "  [1] 启动 Caddy"
    echo "  [2] 停止 Caddy"
    echo "  [3] 重启 Caddy"
    echo "  [4] 重载配置"
    echo "  [5] 查看状态"
    echo "  [6] 查看日志"
    echo "  [0] 返回"
    echo ""
    
    read -p "请选择操作 [0-6]: " choice
    
    case $choice in
        1)
            systemctl start caddy
            success_msg "Caddy 已启动"
            ;;
        2)
            systemctl stop caddy
            success_msg "Caddy 已停止"
            ;;
        3)
            systemctl restart caddy
            success_msg "Caddy 已重启"
            ;;
        4)
            caddy validate --config "$CADDYFILE" && systemctl reload caddy
            success_msg "配置已重载"
            ;;
        5)
            systemctl status caddy --no-pager
            ;;
        6)
            echo ""
            echo "最近 50 行日志:"
            journalctl -u caddy -n 50 --no-pager
            ;;
        0)
            return
            ;;
        *)
            warning_msg "无效选择"
            ;;
    esac
    
    echo ""
    read -p "按 Enter 继续..."
}

# ============================================
# 主菜单
# ============================================
main_menu() {
    while true; do
        show_logo
        echo -e "${CYAN}==================== 主菜单 ====================${NC}\n"
        echo "  [1] 环境检查"
        echo "  [2] 安装/更新 Caddy"
        echo "  [3] 添加服务"
        echo "  [4] 查看服务"
        echo "  [5] 删除服务"
        echo "  [6] 管理服务"
        echo "  [7] 配置防火墙"
        echo "  [0] 退出"
        echo ""
        
        read -p "请选择操作 [0-7]: " choice
        
        case $choice in
            1)
                full_environment_check
                ;;
            2)
                install_caddy
                ;;
            3)
                add_service
                ;;
            4)
                view_services
                ;;
            5)
                remove_service
                ;;
            6)
                manage_caddy_service
                ;;
            7)
                configure_firewall
                read -p "按 Enter 继续..."
                ;;
            0)
                echo -e "\n${GREEN}感谢使用！${NC}\n"
                exit 0
                ;;
            *)
                warning_msg "无效选择"
                sleep 1
                ;;
        esac
    done
}

# ============================================
# 程序入口
# ============================================
main() {
    # 创建日志文件
    touch "$LOG_FILE"
    
    # 首次运行自动环境检查
    if [ ! -f "/tmp/caddy_script_first_run" ]; then
        full_environment_check
        touch "/tmp/caddy_script_first_run"
    fi
    
    # 进入主菜单
    main_menu
}

# 运行主程序
main
