#!/bin/bash

################################################################################
#
# Caddy 交互式多服务管理脚本 v2.0
# 
# 功能：自动安装 Caddy，管理多个服务的 HTTPS 反向代理
# 作者：Claude AI
# 更新：2025-11-03
#
################################################################################

# ============================================================================
# 📖 使用说明
# ============================================================================
#
# 🚀 快速开始：
#   1. 下载脚本：wget https://your-url/caddy_setup.sh
#   2. 添加权限：chmod +x caddy_setup.sh
#   3. 运行脚本：sudo ./caddy_setup.sh
#
# ============================================================================
# 🎯 核心概念
# ============================================================================
#
# 【前端端口】Caddy 监听的端口（用户访问）
#   - 标准：80 (HTTP) / 443 (HTTPS)
#   - 自定义：8443, 8080 等任意端口
#
# 【后端端口】你的服务运行的端口（Caddy 转发到这里）
#   - 例如：14301, 8080, 3000 等
#
# 【工作流程】
#   用户访问 https://yourdomain.com:443 (前端)
#        ↓
#   Caddy 监听 443 端口，接收请求
#        ↓
#   Caddy 转发到 localhost:14301 (后端)
#        ↓
#   你的服务处理请求并返回
#
# ============================================================================
# 📋 典型使用场景
# ============================================================================
#
# 【场景 1】多个子域名共享 443 端口（推荐）
#   配置：
#     - api.example.com    → localhost:14301
#     - web.example.com    → localhost:8080
#     - admin.example.com  → localhost:9000
#   
#   操作：
#     1. 确保 DNS 解析：api.example.com → VPS IP
#     2. 运行脚本 → [3] 添加服务
#     3. 选择 [1] 使用域名
#     4. 输入域名：api.example.com
#     5. 启用 HTTPS：y
#     6. 后端端口：14301
#     7. 重复步骤添加其他服务
#
#   结果：
#     - 所有服务都用 443 端口
#     - Caddy 自动根据域名分流
#     - 自动申请 SSL 证书
#
# ----------------------------------------------------------------------------
#
# 【场景 2】使用自定义端口
#   配置：
#     - example.com:8443 → localhost:14301
#   
#   操作：
#     1. 运行脚本 → [3] 添加服务
#     2. 选择 [2] 使用域名 + 自定义端口
#     3. 输入域名：example.com
#     4. 自定义端口：8443
#     5. 启用 HTTPS：y
#     6. 后端端口：14301
#
#   结果：
#     - 用户访问 https://example.com:8443
#     - Caddy 监听 8443，转发到 localhost:14301
#
# ----------------------------------------------------------------------------
#
# 【场景 3】仅用 IP 访问（无域名）
#   配置：
#     - http://1.2.3.4:8080 → localhost:3000
#   
#   操作：
#     1. 运行脚本 → [3] 添加服务
#     2. 选择 [3] 仅使用 IP:端口
#     3. 服务端口：8080
#     4. 后端端口：3000
#
#   结果：
#     - 用户访问 http://your-ip:8080
#     - 不提供 HTTPS（因为没有域名）
#
# ============================================================================
# 🔍 查看配置
# ============================================================================
#
# 方法 1：使用脚本
#   sudo ./caddy_setup.sh
#   选择 [4] 查看服务
#
# 方法 2：查看配置文件
#   cat /etc/caddy/Caddyfile
#
# 方法 3：快速查看端口映射
#   grep -E "^[^#].*\{|reverse_proxy" /etc/caddy/Caddyfile | grep -v "header"
#
# 方法 4：查看运行状态
#   systemctl status caddy
#   journalctl -u caddy -f
#
# ============================================================================
# ⚠️ 常见问题
# ============================================================================
#
# Q1：提示端口被占用？
# A1：检查是前端端口还是后端端口
#     - 如果是后端端口（如 14301）：正常！你的服务就在这个端口
#     - 如果是前端端口（如 443）：可能有其他 Web 服务器运行
#       解决：停止其他服务或使用不同的前端端口
#
# Q2：如何在 443 端口提供多个服务？
# A2：使用不同的子域名！
#     - api.example.com:443   → 服务 A
#     - web.example.com:443   → 服务 B
#     - admin.example.com:443 → 服务 C
#     Caddy 会根据域名自动分流
#
# Q3：SSL 证书申请失败？
# A3：检查以下项：
#     - 域名是否正确解析到 VPS IP
#     - 80 和 443 端口是否开放
#     - 防火墙是否允许访问
#
# Q4：如何删除某个服务？
# A4：运行脚本 → [5] 删除服务 → 输入域名/地址
#
# Q5：后端服务没有响应？
# A5：检查：
#     - 后端服务是否正在运行：netstat -tlnp | grep 14301
#     - 后端地址是否正确（通常是 localhost）
#     - 查看日志：journalctl -u caddy -f
#
# ============================================================================
# 🛠️ 支持的系统
# ============================================================================
#
# 操作系统：Ubuntu, Debian, CentOS, Rocky Linux, AlmaLinux, Fedora, Alpine
# 架构：x86_64, ARM64, ARMv7, ARMv6
# 防火墙：UFW, firewalld, iptables
#
# ============================================================================
# 📞 脚本功能菜单
# ============================================================================
#
# [1] 环境检查      - 检测系统、架构、冲突等
# [2] 安装 Caddy    - 自动安装或更新 Caddy
# [3] 添加服务      - 配置新的反向代理
# [4] 查看服务      - 查看所有配置
# [5] 删除服务      - 删除指定服务
# [6] 管理服务      - 启动/停止/重启 Caddy
# [7] 配置防火墙    - 开放必要端口
# [0] 退出
#
################################################################################

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

CADDYFILE="/etc/caddy/Caddyfile"
CONFIG_BACKUP="/etc/caddy/Caddyfile.backup"
LOG_FILE="/var/log/caddy_setup.log"

# 系统信息
OS_TYPE=""
OS_VERSION=""
ARCH=""
PACKAGE_MANAGER=""
FIREWALL_TYPE=""
HAS_SYSTEMD=false

# ============================================
# 日志函数
# ============================================
log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1" >> "$LOG_FILE"
}

error_exit() {
    echo -e "${RED}[错误] $1${NC}"
    log "ERROR: $1"
    exit 1
}

success_msg() {
    echo -e "${GREEN}[成功] $1${NC}"
    log "SUCCESS: $1"
}

warning_msg() {
    echo -e "${YELLOW}[警告] $1${NC}"
    log "WARNING: $1"
}

info_msg() {
    echo -e "${BLUE}[信息] $1${NC}"
    log "INFO: $1"
}

# ============================================
# 显示 Logo
# ============================================
show_logo() {
    clear
    echo -e "${GREEN}"
    echo "╔════════════════════════════════════════╗"
    echo "║     Caddy 多服务管理脚本 v2.0         ║"
    echo "║      完整环境检查 + 冲突检测          ║"
    echo "╚════════════════════════════════════════╝"
    echo -e "${NC}"
}

# ============================================
# 检查 root 权限
# ============================================
check_root() {
    if [[ $EUID -ne 0 ]]; then
        error_exit "此脚本需要 root 权限运行，请使用: sudo bash $0"
    fi
}

# ============================================
# 检测系统架构
# ============================================
detect_arch() {
    info_msg "检测系统架构..."
    ARCH=$(uname -m)
    
    case $ARCH in
        x86_64)
            ARCH="amd64"
            success_msg "架构: x86_64 (amd64)"
            ;;
        aarch64|arm64)
            ARCH="arm64"
            success_msg "架构: ARM64"
            ;;
        armv7l)
            ARCH="armv7"
            success_msg "架构: ARMv7"
            ;;
        armv6l)
            ARCH="armv6"
            success_msg "架构: ARMv6"
            ;;
        *)
            error_exit "不支持的架构: $ARCH"
            ;;
    esac
}

# ============================================
# 检测操作系统
# ============================================
detect_os() {
    info_msg "检测操作系统..."
    
    if [ -f /etc/os-release ]; then
        . /etc/os-release
        OS_TYPE=$ID
        OS_VERSION=$VERSION_ID
        
        case $OS_TYPE in
            ubuntu|debian)
                PACKAGE_MANAGER="apt"
                success_msg "系统: $PRETTY_NAME"
                ;;
            centos|rhel|rocky|almalinux)
                PACKAGE_MANAGER="yum"
                success_msg "系统: $PRETTY_NAME"
                ;;
            fedora)
                PACKAGE_MANAGER="dnf"
                success_msg "系统: $PRETTY_NAME"
                ;;
            alpine)
                PACKAGE_MANAGER="apk"
                success_msg "系统: $PRETTY_NAME"
                ;;
            *)
                warning_msg "未知系统: $PRETTY_NAME，尝试继续..."
                ;;
        esac
    else
        error_exit "无法检测操作系统"
    fi
}

# ============================================
# 检查 systemd
# ============================================
check_systemd() {
    info_msg "检查 systemd..."
    if command -v systemctl &> /dev/null; then
        HAS_SYSTEMD=true
        success_msg "systemd 已安装"
    else
        warning_msg "系统未使用 systemd，部分功能可能受限"
    fi
}

# ============================================
# 检测防火墙
# ============================================
detect_firewall() {
    info_msg "检测防火墙..."
    
    if command -v ufw &> /dev/null; then
        FIREWALL_TYPE="ufw"
        success_msg "检测到 UFW 防火墙"
    elif command -v firewall-cmd &> /dev/null; then
        FIREWALL_TYPE="firewalld"
        success_msg "检测到 firewalld 防火墙"
    elif command -v iptables &> /dev/null; then
        FIREWALL_TYPE="iptables"
        success_msg "检测到 iptables 防火墙"
    else
        FIREWALL_TYPE="none"
        warning_msg "未检测到防火墙"
    fi
}

# ============================================
# 检查端口冲突
# ============================================
check_port_conflicts() {
    info_msg "检查端口 80 和 443..."
    
    local conflicts=()
    
    # 检查 80 端口
    if ss -tunlp | grep -q ":80 "; then
        local process=$(ss -tunlp | grep ":80 " | awk '{print $7}' | head -1)
        conflicts+=("端口 80 被占用: $process")
    fi
    
    # 检查 443 端口
    if ss -tunlp | grep -q ":443 "; then
        local process=$(ss -tunlp | grep ":443 " | awk '{print $7}' | head -1)
        conflicts+=("端口 443 被占用: $process")
    fi
    
    if [ ${#conflicts[@]} -gt 0 ]; then
        warning_msg "发现端口冲突:"
        for conflict in "${conflicts[@]}"; do
            echo -e "  ${YELLOW}- $conflict${NC}"
        done
        echo ""
        read -p "是否继续？可能需要停止冲突服务 (y/n): " choice
        if [[ ! $choice =~ ^[Yy]$ ]]; then
            exit 0
        fi
    else
        success_msg "端口 80 和 443 可用"
    fi
}

# ============================================
# 检查其他 Web 服务器
# ============================================
check_web_servers() {
    info_msg "检查其他 Web 服务器..."
    
    local conflicts=()
    
    # 检查 Nginx
    if command -v nginx &> /dev/null; then
        if systemctl is-active --quiet nginx 2>/dev/null; then
            conflicts+=("Nginx (运行中)")
        else
            conflicts+=("Nginx (已安装未运行)")
        fi
    fi
    
    # 检查 Apache
    if command -v apache2 &> /dev/null || command -v httpd &> /dev/null; then
        if systemctl is-active --quiet apache2 2>/dev/null || systemctl is-active --quiet httpd 2>/dev/null; then
            conflicts+=("Apache (运行中)")
        else
            conflicts+=("Apache (已安装未运行)")
        fi
    fi
    
    if [ ${#conflicts[@]} -gt 0 ]; then
        warning_msg "检测到其他 Web 服务器:"
        for conflict in "${conflicts[@]}"; do
            echo -e "  ${YELLOW}- $conflict${NC}"
        done
        echo ""
        echo "建议操作:"
        echo "  1. 停止其他服务: systemctl stop nginx apache2"
        echo "  2. 禁用自启动: systemctl disable nginx apache2"
        echo ""
        read -p "是否自动停止并禁用这些服务? (y/n): " choice
        if [[ $choice =~ ^[Yy]$ ]]; then
            systemctl stop nginx apache2 httpd 2>/dev/null || true
            systemctl disable nginx apache2 httpd 2>/dev/null || true
            success_msg "已停止其他 Web 服务器"
        fi
    else
        success_msg "未检测到冲突的 Web 服务器"
    fi
}

# ============================================
# 检查必要工具
# ============================================
check_dependencies() {
    info_msg "检查必要工具..."
    
    local missing=()
    
    # 必须工具
    for tool in curl wget; do
        if ! command -v $tool &> /dev/null; then
            missing+=($tool)
        fi
    done
    
    if [ ${#missing[@]} -gt 0 ]; then
        warning_msg "缺少工具: ${missing[*]}"
        info_msg "正在安装..."
        
        case $PACKAGE_MANAGER in
            apt)
                apt update -qq
                apt install -y ${missing[*]}
                ;;
            yum|dnf)
                $PACKAGE_MANAGER install -y ${missing[*]}
                ;;
            apk)
                apk add ${missing[*]}
                ;;
        esac
        success_msg "工具安装完成"
    else
        success_msg "所有必要工具已安装"
    fi
}

# ============================================
# 完整环境检查
# ============================================
full_environment_check() {
    show_logo
    echo -e "${CYAN}==================== 环境检查 ====================${NC}\n"
    
    check_root
    detect_arch
    detect_os
    check_systemd
    detect_firewall
    check_dependencies
    check_web_servers
    check_port_conflicts
    
    echo ""
    echo -e "${CYAN}==================== 检查完成 ====================${NC}"
    echo ""
    echo -e "${GREEN}系统信息总结:${NC}"
    echo -e "  操作系统: $OS_TYPE $OS_VERSION"
    echo -e "  架构: $ARCH"
    echo -e "  包管理器: $PACKAGE_MANAGER"
    echo -e "  防火墙: $FIREWALL_TYPE"
    echo -e "  systemd: $HAS_SYSTEMD"
    echo ""
    
    read -p "按 Enter 继续..." 
}

# ============================================
# 安装 Caddy
# ============================================
install_caddy() {
    show_logo
    echo -e "${CYAN}==================== 安装 Caddy ====================${NC}\n"
    
    if command -v caddy &> /dev/null; then
        local version=$(caddy version | head -1)
        success_msg "Caddy 已安装: $version"
        read -p "是否重新安装? (y/n): " choice
        if [[ ! $choice =~ ^[Yy]$ ]]; then
            return
        fi
    fi
    
    info_msg "开始安装 Caddy..."
    
    case $PACKAGE_MANAGER in
        apt)
            info_msg "使用 APT 安装..."
            apt install -y debian-keyring debian-archive-keyring apt-transport-https curl
            curl -1sLf 'https://dl.cloudsmith.io/public/caddy/stable/gpg.key' | gpg --dearmor -o /usr/share/keyrings/caddy-stable-archive-keyring.gpg
            curl -1sLf 'https://dl.cloudsmith.io/public/caddy/stable/debian.deb.txt' | tee /etc/apt/sources.list.d/caddy-stable.list
            apt update
            apt install -y caddy
            ;;
            
        yum)
            info_msg "使用 YUM 安装..."
            yum install -y yum-plugin-copr
            yum copr enable @caddy/caddy -y
            yum install -y caddy
            ;;
            
        dnf)
            info_msg "使用 DNF 安装..."
            dnf install -y 'dnf-command(copr)'
            dnf copr enable @caddy/caddy -y
            dnf install -y caddy
            ;;
            
        *)
            info_msg "使用官方脚本安装..."
            curl -1sLf 'https://dl.cloudsmith.io/public/caddy/stable/setup.sh' | bash
            ;;
    esac
    
    if command -v caddy &> /dev/null; then
        success_msg "Caddy 安装成功!"
        caddy version
        
        # 启动服务
        if $HAS_SYSTEMD; then
            systemctl enable caddy
            systemctl start caddy
            success_msg "Caddy 服务已启动"
        fi
    else
        error_exit "Caddy 安装失败"
    fi
    
    echo ""
    read -p "按 Enter 继续..."
}

# ============================================
# 配置防火墙
# ============================================
configure_firewall() {
    if [ "$FIREWALL_TYPE" = "none" ]; then
        return
    fi
    
    info_msg "配置防火墙规则..."
    
    case $FIREWALL_TYPE in
        ufw)
            ufw allow 80/tcp comment 'Caddy HTTP'
            ufw allow 443/tcp comment 'Caddy HTTPS'
            if ! ufw status | grep -q "Status: active"; then
                echo ""
                read -p "UFW 未启用，是否启用? (y/n): " choice
                if [[ $choice =~ ^[Yy]$ ]]; then
                    ufw --force enable
                fi
            fi
            success_msg "UFW 规则已添加"
            ;;
            
        firewalld)
            firewall-cmd --permanent --add-service=http
            firewall-cmd --permanent --add-service=https
            firewall-cmd --reload
            success_msg "firewalld 规则已添加"
            ;;
            
        iptables)
            iptables -A INPUT -p tcp --dport 80 -j ACCEPT
            iptables -A INPUT -p tcp --dport 443 -j ACCEPT
            # 尝试保存规则
            if command -v netfilter-persistent &> /dev/null; then
                netfilter-persistent save
            elif command -v iptables-save &> /dev/null; then
                iptables-save > /etc/iptables/rules.v4 2>/dev/null || true
            fi
            success_msg "iptables 规则已添加"
            ;;
    esac
}

