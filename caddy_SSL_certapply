#!/bin/bash

################################################################################
#
# Caddy 交互式多服务管理脚本 v2.3 (管道执行修复版)
# 
# 功能：自动安装 Caddy，管理多个服务的 HTTPS 反向代理
# 修复：完全支持 curl | bash 管道执行
# 更新：2025-11-11
#
################################################################################

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

CADDYFILE="/etc/caddy/Caddyfile"
CONFIG_BACKUP="/etc/caddy/Caddyfile.backup"
LOG_FILE="/var/log/caddy_setup.log"

# 系统信息
OS_TYPE=""
OS_VERSION=""
ARCH=""
PACKAGE_MANAGER=""
FIREWALL_TYPE=""
HAS_SYSTEMD=false

# ============================================
# 修复：强制从 TTY 读取输入
# ============================================
read_from_tty() {
    if [ -t 0 ]; then
        # 标准输入可用
        read "$@"
    else
        # 标准输入被管道占用，从 /dev/tty 读取
        read "$@" </dev/tty
    fi
}

# ============================================
# 智能等待函数
# ============================================
smart_wait() {
    local message="${1:-按 Enter 继续...}"
    echo ""
    read_from_tty -p "$message"
}

# ============================================
# 日志函数
# ============================================
log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1" >> "$LOG_FILE"
}

error_exit() {
    echo -e "${RED}[错误] $1${NC}"
    log "ERROR: $1"
    exit 1
}

success_msg() {
    echo -e "${GREEN}[成功] $1${NC}"
    log "SUCCESS: $1"
}

warning_msg() {
    echo -e "${YELLOW}[警告] $1${NC}"
    log "WARNING: $1"
}

info_msg() {
    echo -e "${BLUE}[信息] $1${NC}"
    log "INFO: $1"
}

# ============================================
# 显示 Logo
# ============================================
show_logo() {
    clear
    echo -e "${GREEN}"
    echo "╔════════════════════════════════════════╗"
    echo "║     Caddy 多服务管理脚本 v2.3         ║"
    echo "║      支持管道执行 (curl|bash)         ║"
    echo "╚════════════════════════════════════════╝"
    echo -e "${NC}"
}

# ============================================
# 检查 root 权限
# ============================================
check_root() {
    if [[ $EUID -ne 0 ]]; then
        error_exit "此脚本需要 root 权限运行，请使用: sudo bash $0"
    fi
}

# ============================================
# 检测系统架构
# ============================================
detect_arch() {
    info_msg "检测系统架构..."
    ARCH=$(uname -m)
    
    case $ARCH in
        x86_64)
            ARCH="amd64"
            success_msg "架构: x86_64 (amd64)"
            ;;
        aarch64|arm64)
            ARCH="arm64"
            success_msg "架构: ARM64"
            ;;
        armv7l)
            ARCH="armv7"
            success_msg "架构: ARMv7"
            ;;
        *)
            error_exit "不支持的架构: $ARCH"
            ;;
    esac
}

# ============================================
# 检测操作系统
# ============================================
detect_os() {
    info_msg "检测操作系统..."
    
    if [ -f /etc/os-release ]; then
        . /etc/os-release
        OS_TYPE=$ID
        OS_VERSION=$VERSION_ID
        
        case $OS_TYPE in
            ubuntu|debian)
                PACKAGE_MANAGER="apt"
                success_msg "系统: $PRETTY_NAME"
                ;;
            centos|rhel|rocky|almalinux)
                PACKAGE_MANAGER="yum"
                success_msg "系统: $PRETTY_NAME"
                ;;
            fedora)
                PACKAGE_MANAGER="dnf"
                success_msg "系统: $PRETTY_NAME"
                ;;
            *)
                warning_msg "未知系统: $PRETTY_NAME"
                ;;
        esac
    else
        error_exit "无法检测操作系统"
    fi
}

# ============================================
# 检查 systemd
# ============================================
check_systemd() {
    if command -v systemctl &> /dev/null; then
        HAS_SYSTEMD=true
        success_msg "systemd 已安装"
    else
        warning_msg "系统未使用 systemd"
    fi
}

# ============================================
# 检测防火墙
# ============================================
detect_firewall() {
    info_msg "检测防火墙..."
    
    if command -v ufw &> /dev/null; then
        FIREWALL_TYPE="ufw"
        success_msg "检测到 UFW 防火墙"
    elif command -v firewall-cmd &> /dev/null; then
        FIREWALL_TYPE="firewalld"
        success_msg "检测到 firewalld 防火墙"
    elif command -v iptables &> /dev/null; then
        FIREWALL_TYPE="iptables"
        success_msg "检测到 iptables 防火墙"
    else
        FIREWALL_TYPE="none"
        warning_msg "未检测到防火墙"
    fi
}

# ============================================
# 检查端口冲突
# ============================================
check_port_conflicts() {
    info_msg "检查端口 80 和 443..."
    
    local conflicts=()
    
    if ss -tunlp 2>/dev/null | grep -q ":80 " || netstat -tunlp 2>/dev/null | grep -q ":80 "; then
        local process=$(ss -tunlp 2>/dev/null | grep ":80 " | awk '{print $7}' | head -1)
        conflicts+=("端口 80 被占用: $process")
    fi
    
    if ss -tunlp 2>/dev/null | grep -q ":443 " || netstat -tunlp 2>/dev/null | grep -q ":443 "; then
        local process=$(ss -tunlp 2>/dev/null | grep ":443 " | awk '{print $7}' | head -1)
        conflicts+=("端口 443 被占用: $process")
    fi
    
    if [ ${#conflicts[@]} -gt 0 ]; then
        warning_msg "发现端口冲突:"
        for conflict in "${conflicts[@]}"; do
            echo -e "  ${YELLOW}- $conflict${NC}"
        done
        echo ""
        read_from_tty -p "是否继续？(y/n): " choice
        if [[ ! $choice =~ ^[Yy]$ ]]; then
            exit 0
        fi
    else
        success_msg "端口 80 和 443 可用"
    fi
}

# ============================================
# 检查其他 Web 服务器
# ============================================
check_web_servers() {
    info_msg "检查其他 Web 服务器..."
    
    local conflicts=()
    
    if command -v nginx &> /dev/null; then
        if systemctl is-active --quiet nginx 2>/dev/null; then
            conflicts+=("Nginx (运行中)")
        fi
    fi
    
    if command -v apache2 &> /dev/null || command -v httpd &> /dev/null; then
        if systemctl is-active --quiet apache2 2>/dev/null || systemctl is-active --quiet httpd 2>/dev/null; then
            conflicts+=("Apache (运行中)")
        fi
    fi
    
    if [ ${#conflicts[@]} -gt 0 ]; then
        warning_msg "检测到其他 Web 服务器:"
        for conflict in "${conflicts[@]}"; do
            echo -e "  ${YELLOW}- $conflict${NC}"
        done
        echo ""
        read_from_tty -p "是否自动停止这些服务? (y/n): " choice
        if [[ $choice =~ ^[Yy]$ ]]; then
            systemctl stop nginx apache2 httpd 2>/dev/null || true
            systemctl disable nginx apache2 httpd 2>/dev/null || true
            success_msg "已停止其他 Web 服务器"
        fi
    else
        success_msg "未检测到冲突的 Web 服务器"
    fi
}

# ============================================
# 检查必要工具
# ============================================
check_dependencies() {
    info_msg "检查必要工具..."
    
    local missing=()
    
    for tool in curl wget; do
        if ! command -v $tool &> /dev/null; then
            missing+=($tool)
        fi
    done
    
    if [ ${#missing[@]} -gt 0 ]; then
        warning_msg "缺少工具: ${missing[*]}"
        info_msg "正在安装..."
        
        case $PACKAGE_MANAGER in
            apt)
                apt update -qq
                apt install -y ${missing[*]}
                ;;
            yum|dnf)
                $PACKAGE_MANAGER install -y ${missing[*]}
                ;;
        esac
        success_msg "工具安装完成"
    else
        success_msg "所有必要工具已安装"
    fi
}

# ============================================
# 完整环境检查
# ============================================
full_environment_check() {
    show_logo
    echo -e "${CYAN}==================== 环境检查 ====================${NC}\n"
    
    check_root
    detect_arch
    detect_os
    check_systemd
    detect_firewall
    check_dependencies
    check_web_servers
    check_port_conflicts
    
    echo ""
    echo -e "${CYAN}==================== 检查完成 ====================${NC}"
    echo ""
    echo -e "${GREEN}系统信息总结:${NC}"
    echo -e "  操作系统: $OS_TYPE $OS_VERSION"
    echo -e "  架构: $ARCH"
    echo -e "  包管理器: $PACKAGE_MANAGER"
    echo -e "  防火墙: $FIREWALL_TYPE"
    echo ""
    
    smart_wait
}

# ============================================
# 安装 Caddy
# ============================================
install_caddy() {
    show_logo
    echo -e "${CYAN}==================== 安装 Caddy ====================${NC}\n"
    
    if command -v caddy &> /dev/null; then
        local version=$(caddy version 2>/dev/null | head -1)
        success_msg "Caddy 已安装: $version"
        
        read_from_tty -p "是否重新安装? (y/n): " choice
        if [[ ! $choice =~ ^[Yy]$ ]]; then
            return
        fi
    fi
    
    info_msg "开始安装 Caddy..."
    
    case $PACKAGE_MANAGER in
        apt)
            info_msg "使用 APT 安装..."
            apt install -y debian-keyring debian-archive-keyring apt-transport-https curl
            curl -1sLf 'https://dl.cloudsmith.io/public/caddy/stable/gpg.key' | gpg --dearmor -o /usr/share/keyrings/caddy-stable-archive-keyring.gpg
            curl -1sLf 'https://dl.cloudsmith.io/public/caddy/stable/debian.deb.txt' | tee /etc/apt/sources.list.d/caddy-stable.list
            apt update
            apt install -y caddy
            ;;
            
        yum)
            info_msg "使用 YUM 安装..."
            yum install -y yum-plugin-copr
            yum copr enable @caddy/caddy -y
            yum install -y caddy
            ;;
            
        dnf)
            info_msg "使用 DNF 安装..."
            dnf install -y 'dnf-command(copr)'
            dnf copr enable @caddy/caddy -y
            dnf install -y caddy
            ;;
    esac
    
    if command -v caddy &> /dev/null; then
        success_msg "Caddy 安装成功!"
        caddy version
        
        mkdir -p /etc/caddy
        
        if $HAS_SYSTEMD; then
            systemctl enable caddy 2>/dev/null || true
            systemctl start caddy 2>/dev/null || true
            success_msg "Caddy 服务已启动"
        fi
    else
        error_exit "Caddy 安装失败"
    fi
    
    smart_wait
}

# ============================================
# 配置防火墙
# ============================================
configure_firewall() {
    if [ "$FIREWALL_TYPE" = "none" ]; then
        warning_msg "未检测到防火墙"
        return
    fi
    
    info_msg "配置防火墙规则..."
    
    case $FIREWALL_TYPE in
        ufw)
            ufw allow 80/tcp 2>/dev/null || true
            ufw allow 443/tcp 2>/dev/null || true
            success_msg "UFW 规则已添加"
            ;;
            
        firewalld)
            firewall-cmd --permanent --add-service=http 2>/dev/null || true
            firewall-cmd --permanent --add-service=https 2>/dev/null || true
            firewall-cmd --reload 2>/dev/null || true
            success_msg "firewalld 规则已添加"
            ;;
            
        iptables)
            iptables -A INPUT -p tcp --dport 80 -j ACCEPT 2>/dev/null || true
            iptables -A INPUT -p tcp --dport 443 -j ACCEPT 2>/dev/null || true
            success_msg "iptables 规则已添加"
            ;;
    esac
}

# ============================================
# 添加服务
# ============================================
add_service() {
    show_logo
    echo -e "${CYAN}==================== 添加服务 ====================${NC}\n"
    
    if [ -f "$CADDYFILE" ]; then
        cp "$CADDYFILE" "$CONFIG_BACKUP"
    fi
    
    echo -e "${YELLOW}1. 配置访问方式${NC}"
    echo "  [1] 域名 (标准 443 端口)"
    echo "  [2] 域名 + 自定义端口 (如 8443)"
    echo "  [3] IP:端口 (如 :8080)"
    echo ""
    
    read_from_tty -p "请选择 [1-3]: " access_type
    
    local use_ssl=false
    local address=""
    local custom_port=""
    
    if [ "$access_type" = "1" ]; then
        read_from_tty -p "请输入域名 (如 api.example.com): " domain
        if [ -z "$domain" ]; then
            error_exit "域名不能为空"
        fi
        address="$domain"
        use_ssl=true
        
    elif [ "$access_type" = "2" ]; then
        read_from_tty -p "请输入域名: " domain
        if [ -z "$domain" ]; then
            error_exit "域名不能为空"
        fi
        
        read_from_tty -p "请输入端口 (如 8443): " custom_port
        if [ -z "$custom_port" ]; then
            error_exit "端口不能为空"
        fi
        
        address="$domain:$custom_port"
        use_ssl=true
        
    else
        read_from_tty -p "请输入端口: " service_port
        if [ -z "$service_port" ]; then
            error_exit "端口不能为空"
        fi
        
        address=":$service_port"
        use_ssl=false
        custom_port="$service_port"
    fi
    
    echo ""
    echo -e "${YELLOW}2. 配置后端服务${NC}"
    read_from_tty -p "后端端口 (如 9000): " backend_port
    if [ -z "$backend_port" ]; then
        error_exit "后端端口不能为空"
    fi
    
    read_from_tty -p "后端地址 [默认: localhost]: " backend_host
    backend_host=${backend_host:-localhost}
    
    # 生成配置
    echo "" >> "$CADDYFILE"
    echo "# 服务: $address" >> "$CADDYFILE"
    echo "$address {" >> "$CADDYFILE"
    echo "    reverse_proxy $backend_host:$backend_port {" >> "$CADDYFILE"
    echo "        header_up X-Real-IP {remote_host}" >> "$CADDYFILE"
    echo "        header_up X-Forwarded-For {remote_addr}" >> "$CADDYFILE"
    echo "        header_up X-Forwarded-Proto {scheme}" >> "$CADDYFILE"
    echo "    }" >> "$CADDYFILE"
    echo "}" >> "$CADDYFILE"
    
    echo ""
    info_msg "验证配置..."
    if caddy validate --config "$CADDYFILE"; then
        success_msg "配置验证成功"
        
        if systemctl reload caddy; then
            success_msg "服务配置成功!"
            echo ""
            echo -e "${GREEN}配置信息:${NC}"
            echo -e "  访问地址: ${CYAN}$address${NC}"
            echo -e "  后端地址: $backend_host:$backend_port"
            
            if [ -n "$custom_port" ]; then
                echo ""
                read_from_tty -p "是否添加防火墙规则 (端口 $custom_port)? (y/n): " fw_choice
                if [[ $fw_choice =~ ^[Yy]$ ]]; then
                    case $FIREWALL_TYPE in
                        ufw)
                            ufw allow $custom_port/tcp 2>/dev/null || true
                            ;;
                        firewalld)
                            firewall-cmd --permanent --add-port=$custom_port/tcp 2>/dev/null || true
                            firewall-cmd --reload 2>/dev/null || true
                            ;;
                    esac
                    success_msg "防火墙规则已添加"
                fi
            fi
        else
            error_exit "重载失败"
            cp "$CONFIG_BACKUP" "$CADDYFILE"
        fi
    else
        error_exit "配置验证失败"
        cp "$CONFIG_BACKUP" "$CADDYFILE"
    fi
    
    smart_wait
}

# ============================================
# 查看服务
# ============================================
view_services() {
    show_logo
    echo -e "${CYAN}==================== 当前服务 ====================${NC}\n"
    
    if [ ! -f "$CADDYFILE" ]; then
        warning_msg "配置文件不存在"
        smart_wait
        return
    fi
    
    echo -e "${GREEN}Caddyfile 配置:${NC}"
    echo "─────────────────────────────────────────────"
    cat "$CADDYFILE"
    echo "─────────────────────────────────────────────"
    
    smart_wait
}

# ============================================
# 删除服务
# ============================================
remove_service() {
    show_logo
    echo -e "${CYAN}==================== 删除服务 ====================${NC}\n"
    
    if [ ! -f "$CADDYFILE" ]; then
        warning_msg "配置文件不存在"
        smart_wait
        return
    fi
    
    echo -e "${YELLOW}当前服务:${NC}\n"
    grep -E "^[^#]*\{" "$CADDYFILE" | sed 's/ {//' | nl -w2 -s'. '
    
    echo ""
    read_from_tty -p "输入要删除的域名/地址: " target
    
    if [ -z "$target" ]; then
        warning_msg "已取消"
        smart_wait
        return
    fi
    
    cp "$CADDYFILE" "$CONFIG_BACKUP"
    
    sed -i "/^# 服务: $target/,/^}/d" "$CADDYFILE"
    sed -i "/^$target {/,/^}/d" "$CADDYFILE"
    
    if caddy validate --config "$CADDYFILE" && systemctl reload caddy; then
        success_msg "服务已删除"
    else
        error_exit "删除失败"
        cp "$CONFIG_BACKUP" "$CADDYFILE"
    fi
    
    smart_wait
}

# ============================================
# 管理服务
# ============================================
manage_caddy_service() {
    show_logo
    echo -e "${CYAN}==================== 服务管理 ====================${NC}\n"
    
    echo "  [1] 启动 Caddy"
    echo "  [2] 停止 Caddy"
    echo "  [3] 重启 Caddy"
    echo "  [4] 重载配置"
    echo "  [5] 查看状态"
    echo "  [6] 查看日志"
    echo "  [0] 返回"
    echo ""
    
    read_from_tty -p "请选择 [0-6]: " choice
    
    case $choice in
        1) systemctl start caddy; success_msg "已启动" ;;
        2) systemctl stop caddy; success_msg "已停止" ;;
        3) systemctl restart caddy; success_msg "已重启" ;;
        4) systemctl reload caddy; success_msg "已重载" ;;
        5) systemctl status caddy --no-pager ;;
        6) journalctl -u caddy -n 50 --no-pager ;;
        0) return ;;
    esac
    
    smart_wait
}

# ============================================
# 主菜单
# ============================================
main_menu() {
    while true; do
        show_logo
        echo -e "${CYAN}==================== 主菜单 ====================${NC}\n"
        echo "  [1] 环境检查"
        echo "  [2] 安装 Caddy"
        echo "  [3] 添加服务"
        echo "  [4] 查看服务"
        echo "  [5] 删除服务"
        echo "  [6] 管理服务"
        echo "  [7] 配置防火墙"
        echo "  [0] 退出"
        echo ""
        
        read_from_tty -p "请选择 [0-7]: " choice
        
        case $choice in
            1) full_environment_check ;;
            2) install_caddy ;;
            3) add_service ;;
            4) view_services ;;
            5) remove_service ;;
            6) manage_caddy_service ;;
            7) configure_firewall; smart_wait ;;
            0) echo -e "\n${GREEN}再见!${NC}\n"; exit 0 ;;
            *) warning_msg "无效选择"; sleep 1 ;;
        esac
    done
}

# ============================================
# 程序入口
# ============================================
main() {
    touch "$LOG_FILE" 2>/dev/null || LOG_FILE="/tmp/caddy_setup.log"
    
    # 显示欢迎信息
    show_logo
    echo -e "${CYAN}检测到通过管道执行，已修复交互问题${NC}"
    echo ""
    sleep 2
    
    # 进入主菜单
    main_menu
}

main "$@"